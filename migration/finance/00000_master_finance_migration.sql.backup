    EXISTS (
      SELECT 1 FROM user_roles
      WHERE user_roles.user_id = auth.uid()
      AND user_roles.role::text IN ('admin::textfinance_admin::textfinance_manager'::text)
    )
  );

-- Admin and finance users can update invoices
DROP POLICY IF EXISTS "Finance users can update invoices" ON finance_invoices;
CREATE POLICY "Finance users can update invoices"
  ON finance_invoices FOR UPDATE
  USING (
    EXISTS (
      SELECT 1 FROM user_roles
      WHERE user_roles.user_id = auth.uid()
      AND user_roles.role::text IN ('admin::textfinance_admin::textfinance_manager'::text)
    )
  );

-- Admin can delete invoices
DROP POLICY IF EXISTS "Admin can delete invoices" ON finance_invoices;
CREATE POLICY "Admin can delete invoices"
  ON finance_invoices FOR DELETE
  USING (
    EXISTS (
      SELECT 1 FROM profiles p
      WHERE p.id = auth.uid()
      AND p.main_role::text = 'admin'::text
    )
  );

