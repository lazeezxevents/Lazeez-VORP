CREATE POLICY "Finance users can view all line items"
  ON finance_invoice_line_items FOR SELECT
  USING (
    EXISTS (
      SELECT 1 FROM user_roles
      WHERE user_roles.user_id = auth.uid()
      AND user_roles.role::text IN ('admin::textfinance_admin::textfinance_manager'::text)
    )
  );

-- Finance users can insert line items
DROP POLICY IF EXISTS "Finance users can insert line items" ON finance_invoice_line_items;
