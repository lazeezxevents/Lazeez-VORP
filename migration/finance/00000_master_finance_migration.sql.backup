CREATE POLICY "finance_invoice_line_items_vendor_select" ON finance_invoice_line_items FOR SELECT TO authenticated USING (
      EXISTS (
        SELECT 1 FROM finance_invoices fi
        JOIN vendors v ON v.id = fi.vendor_id
