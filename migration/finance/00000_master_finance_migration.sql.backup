CREATE POLICY "finance_expenses_employee_update" ON finance_expenses FOR UPDATE TO authenticated USING (is_record_owner(employee_id) AND status::text = 'draft'::text) WITH CHECK (is_record_owner(employee_id) AND status::text = 'draft'::text);
  END IF;
END $$;

