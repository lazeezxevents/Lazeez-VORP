# Supabase Configuration
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Configuration (Groq)
VITE_GROQ_API_KEY=your-groq-api-key

# WebSocket Configuration (Communication Module)
# Development: ws://localhost:8080
# Production: wss://ws.your-domain.com
VITE_WS_URL=ws://localhost:8080

# WebRTC TURN Server Configuration (Optional for development, Required for production)
# Leave empty for development if testing on same network
# For production, configure a TURN server for NAT traversal
# See docs/WEBRTC_SETUP_GUIDE.md for setup instructions

# TURN Server URL (e.g., turn:turn.your-domain.com:3478)
VITE_TURN_URL=

# TURN Server Username
VITE_TURN_USERNAME=

# TURN Server Credential/Password
VITE_TURN_CREDENTIAL=

# Note: STUN servers (Google's public STUN) are used by default and don't require configuration
# STUN: stun:stun.l.google.com:19302
# STUN: stun:stun1.l.google.com:19302
